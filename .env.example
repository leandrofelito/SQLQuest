# Copie para .env.local e preencha. Não commite segredos.

# Neon — produção: DATABASE_URL = connection string com POOLER (*.pooler.neon.tech) + ?sslmode=require
# DIRECT_URL = conexão direta (host sem "pooler", porta 5432) para prisma migrate / db push
# Desenvolvimento local sem pooler: pode repetir a mesma string nas duas variáveis.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Incremente quando publicar novo conteúdo de trilhas/etapas (invalida cache offline no app)
CONTENT_VERSION="1"

NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
ADMIN_EMAILS=""

# Google AdSense (site web) — script e blocos só ativam com ID + slots preenchidos.
# No painel AdSense crie unidades "Display" e copie o ID do slot (número). Mantenha ads.txt
# em public/ads.txt alinhado ao mesmo publisher (pub-…).
# NEXT_PUBLIC_ADSENSE_LOAD_SCRIPT="false"  # opcional: desliga o script (homologação)
NEXT_PUBLIC_ADSENSE_ID="ca-pub-your_publisher_id_here"
NEXT_PUBLIC_ADSENSE_SLOT="your_banner_display_ad_unit_id"
# Opcional: banner só no modal de estrelas (relatórios AdSense); se vazio, usa NEXT_PUBLIC_ADSENSE_SLOT
NEXT_PUBLIC_ADSENSE_SLOT_BANNER_ESTRELAS=""
NEXT_PUBLIC_ADSENSE_SLOT_TRILHA_MODAL="your_modal_or_in_feed_ad_unit_id"
