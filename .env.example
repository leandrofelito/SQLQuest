# Copie para .env.local e preencha. Nao commite segredos.

# PostgreSQL local. Use o mesmo valor nas duas variaveis neste ambiente.
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/sqlquest_local"
DIRECT_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/sqlquest_local"

# Incremente quando publicar novo conteudo de trilhas/etapas (invalida cache offline no app)
CONTENT_VERSION="1"

NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_URL="http://localhost:3000"
ADMIN_EMAILS=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Resend
RESEND_API_KEY=""
EMAIL_FROM="SQLQuest <noreply@sqlquest.com.br>"

# Google AdSense (site web). Script e blocos so ativam com ID + slots preenchidos.
# NEXT_PUBLIC_ADSENSE_LOAD_SCRIPT="false"  # opcional: desliga o script em homologacao
NEXT_PUBLIC_ADSENSE_ID="ca-pub-your_publisher_id_here"
NEXT_PUBLIC_ADSENSE_SLOT="your_banner_display_ad_unit_id"
# Opcional: banner so no modal de estrelas; se vazio, usa NEXT_PUBLIC_ADSENSE_SLOT
NEXT_PUBLIC_ADSENSE_SLOT_BANNER_ESTRELAS=""
NEXT_PUBLIC_ADSENSE_SLOT_TRILHA_MODAL="your_modal_or_in_feed_ad_unit_id"

TOKEN_SECRET=""
MAINTENANCE_MODE=false
