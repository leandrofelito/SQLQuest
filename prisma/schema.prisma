generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  /// Conexão direta (porta 5432 / host sem pooler) — obrigatória para `prisma migrate` / `db push`.
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  nickname       String?   @unique
  image          String?
  password       String?
  isPro        Boolean   @default(false)
  isAdmin      Boolean   @default(false)
  proAt        DateTime?
  totalXp      Int       @default(0)
  /// XP acumulado para o ranking global (só aumenta; não zera ao prestigiar).
  xpRanking    Int       @default(0)
  streak       Int       @default(0)
  prestige            Int       @default(0)
  language_preference String    @default("pt")
  lastActiveAt        DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  progressos            Progresso[]
  pagamentos            Pagamento[]
  certificados          Certificado[]
  conquistasRanking     ConquistaRanking[]
  trilhasDesbloqueadas  TrilhaDesbloqueada[]

  @@index([totalXp(sort: Desc)])
  @@index([xpRanking(sort: Desc)])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Trilha {
  id          String   @id @default(cuid())
  slug        String   @unique
  titulo      String
  descricao   String
  icone       String
  ordem       Int      @unique
  totalEtapas Int
  xpTotal     Int
  publicada   Boolean  @default(false)
  traducoes   Json?
  criadaEm   DateTime @default(now())

  etapas               Etapa[]
  progressos           Progresso[]
  certificados         Certificado[]
  trilhasDesbloqueadas TrilhaDesbloqueada[]
}

model Etapa {
  id         String   @id @default(cuid())
  trilhaId   String
  ordem      Int
  tipo       String
  titulo     String
  conteudo   Json
  traducoes  Json?
  xpReward   Int      @default(50)
  temAnuncio Boolean  @default(false)
  criadaEm  DateTime @default(now())

  trilha     Trilha      @relation(fields: [trilhaId], references: [id], onDelete: Cascade)
  progressos Progresso[]

  @@unique([trilhaId, ordem])
}

model Progresso {
  id           String   @id @default(cuid())
  userId       String
  trilhaId     String
  etapaId      String
  xpGanho      Int      @default(0)
  tentativas   Int      @default(1)
  usouDica     Boolean  @default(false)
  estrelas     Int      @default(0)
  concluidaEm DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  trilha Trilha @relation(fields: [trilhaId], references: [id], onDelete: Cascade)
  etapa  Etapa  @relation(fields: [etapaId], references: [id], onDelete: Cascade)

  @@unique([userId, etapaId])
  @@index([userId])
  @@index([userId, trilhaId])
}

model Pagamento {
  id              String   @id @default(cuid())
  userId          String
  stripeSessionId String   @unique
  valor           Int
  status          String   @default("pending")
  criadoEm       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConquistaRanking {
  id          String   @id @default(cuid())
  userId      String
  tipo        String   // "top1" | "top10" | "top100" | "top1000"
  posicao     Int
  alcancadaEm DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tipo])
}

model Certificado {
  id         String   @id @default(cuid())
  userId     String
  trilhaId   String
  hash       String   @unique @default(cuid())
  emitidoEm DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  trilha Trilha @relation(fields: [trilhaId], references: [id], onDelete: Cascade)

  @@unique([userId, trilhaId])
  @@index([userId])
}

model TrilhaDesbloqueada {
  id        String   @id @default(cuid())
  userId    String
  trilhaId  String
  criadaEm DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  trilha Trilha @relation(fields: [trilhaId], references: [id], onDelete: Cascade)

  @@unique([userId, trilhaId])
  @@index([userId])
}

/// Contador distribuído de rate limiting — funciona em ambientes serverless com múltiplas instâncias.
model RateLimit {
  key     String   @id
  count   Int      @default(1)
  resetAt DateTime @map("reset_at")

  @@map("rate_limit")
}
